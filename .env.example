# Copy this file to .env and fill in the values before running docker-compose.
# NEVER commit .env to version control.

# Admin credentials for /api/auth/login
# Without ADMIN_PASSWORD set, any password is accepted (dev mode only!)
ADMIN_EMAIL=admin@yourorg.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# LLM model configuration (llama-cpp-python backend).
# LLM_MODEL_PATH — absolute path to a single .gguf model file.
# AUTON8_MODELS_DIR — directory containing .gguf files (first match is used).
# If neither is set, ~/models is searched automatically.
# LLM features (intent classification, recovery planning) are disabled if no model is found.
# LLM_MODEL_PATH=/opt/models/mistral-7b-instruct.Q4_K_M.gguf
# AUTON8_MODELS_DIR=/opt/models
LLM_N_CTX=4096
LLM_N_THREADS=4
LLM_N_GPU_LAYERS=0

# Path to the data directory on the server.
# Defaults to <project_root>/data — only set this if you need a custom location.
# In Docker this is always /app/data (set in docker-compose.yml directly).
# DATA_DIR=/opt/auton8/data

# Allowed CORS origins — comma-separated list of recorder client origins.
# Set to * only for local dev. In production use the actual IPs/hostnames.
# Example: CORS_ORIGINS=http://192.168.1.10,http://tester1.internal
CORS_ORIGINS=*

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
